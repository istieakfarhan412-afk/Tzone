rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isServerTimestamp(field) {
      return field == request.time;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && (data.role == 'user'); // Users cannot set themselves as admin
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.category in ['Tech', 'Fashion', 'Skincare']
        && (data.stock is int && data.stock >= 0);
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.items is list && data.items.size() > 0
        && data.total is number && data.total >= 0
        && data.status == 'pending'; // Initial status must be pending
    }

    function isValidReview(data) {
      return data.userId == request.auth.uid
        && data.productId is string
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && (data.comment == null || (data.comment is string && data.comment.size() <= 2000));
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'updatedAt']);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn(); // Allow checking if user is admin
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin() || (isOwner(existing().userId) && incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['shippingAddress', 'updatedAt']));
    }

    match /products/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming()) && incoming().productId == productId;
      allow update: if isOwner(existing().userId) && isValidReview(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /users/{userId}/cart/{cartId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/wishlist/{wishlistId} {
      allow read, write: if isOwner(userId);
    }
  }
}
